<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css"
      integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/style.css">

    <title>Book Journal Portfolio Project</title>
  </head>
  <body>
    <main>
      <%- include('header.ejs')%>
      <%- include('header_wave.ejs') %>
      <div class="album py-5 pb-4">
        <div class="container">
          <div class="row">
            <div class="col-12">
              <div class="card shadow-sm">
                <form class="px-2 py-1" action="/login" method="POST">
                <div class="form-group">
                    <label for="user">username</label>
                    <input type="text" class="form-control" id="user" name="user">
                </div>
                <div class="form-group">
                    <label for="password">password</label>
                    <input type="text" class="form-control" id="password" name="password">
                </div>
                <button type="submit" class="btn primary-button">Submit</button>
                <a href="/ "></a><button class="btn secondary-button">Cancel</button></a>
                </form>
                
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <%- include('footer.ejs')%>
    <%- include('script.ejs'); %>
  </body>
</html>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css"
      integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm"
      crossorigin="anonymous"
    />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css" />

    <title>Book Journal Portfolio Project</title>
  </head>
  <body style="background-color: #C5A27D">
    <main style="background-color: #C5A27D">
      <%- include('header.ejs')%> <%- include('header_wave.ejs') %>
      <div class="container my-5">
        <!-- Title Section -->
        <div class="text-center mb-5">
          <h1 class="display-4 fw-bold text-on-brown add-serif"><%=data.title%></h1>
          <h2 class="fs-5 text-on-brown opacity-75 add-serif"><%=data.author%></p>
        </div>

        <!-- Two Column Layout -->
        <div class="row g-4 align-items-start">
          <!-- Book Cover -->
          <div class="col-md-4 text-center">
            <div
              class="d-inline-block rounded"
              style="
                background-color: #ece0d1; /* cream */
                padding: 5px; /* space around the image */
                border-radius: 8px; /* smooth corners */
                box-shadow: 0 6px 18px rgba(56, 34, 15, 0.45); /* warm dark shadow */
              "
            >
              <img
                src="/images/<%=data.isbn%>.png"
                class="img-fluid rounded"
                style="max-width: 250px"
                alt="Book cover for <%=data.title%> by <%=data.author%>"
              />
            </div>
          </div>

          <!-- Description + Metadata -->
          <div class="col-md-8">
            <div class="text-block-wrapper" style="max-width: 600px">
              <div class="mb-3">
                <% const star = "★" %>
                <span class="metadata-line text-on-brown">
                  Rating: <%= star.repeat(data.rating) %>
                </span>
              </div>
              <div class="mb-3">
                <span class="metadata-line text-on-brown">
                  Finished: <%=data.month%> <%=data.year%>
                </span>
              </div>
              <p class="lead notes-text text-on-brown">
                <%- (data.notes || "").replace(/\n/g, '<br />') %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>
    <%- include('footer.ejs'); %> <%- include('script.ejs'); %>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css"
      integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/style.css">

    <title>Book Journal Portfolio Project</title>
  </head>
  <body>
    <main>
      <%- include('header.ejs')%>
      <%- include('header_wave.ejs') %>
      <div class="album py-5 pb-4">
        <div class="container">
          <div class="row">
            <div class="col-12">
              <div class="shadow-sm td-flex mx-3">
                <img class="mx-3" src="/images/<%=data.isbn%>.png" style="height:200px; width:150px; float:left; border:5px solid #FFFFFF">
                <h2 style="color:white"><%=data.title%> - <%=data.author%></h2>
                <p style="color:white"><%- (data.notes || "").replace(/\n/g, '<br>') %>
                </p>
              </div>
            </div>
            <!-- <div class="mt-3 ml-4">
              <a href="/" class="btn btn-light">Back to home</a>
              <a href="/edit?id=<%=data.id%>" class="btn btn-outline-light">Edit</a>
            </div> -->
          </div>
        </div>
      </div>
    </main>
    <%- include('footer.ejs'); %>
    <%- include('script.ejs'); %>
  </body>
</html>

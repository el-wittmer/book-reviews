
  <body style="background-color: #C5A27D">
    <main style="background-color: #C5A27D">
      <%- include('header.ejs')%> <%- include('header_wave.ejs') %>
      <div class="container my-5">
        <!-- Title Section -->
        <div class="text-center mb-5">
          <h2 class="display-4 fw-bold"><%=data.title%></h2>
          <h3 class="fs-5 opacity-75" style="font-size:1.5rem;"><%=data.author%></h3>
        </div>

        <!-- Two Column Layout -->
        <div class="row g-4 align-items-start">
          <!-- Book Cover -->
          <div class="col-md-4 text-center">
            <div
              class="d-inline-block rounded"
              style="
                background-color: #ece0d1; /* cream */
                padding: 5px; /* space around the image */
                border-radius: 8px; /* smooth corners */
                box-shadow: 0 6px 18px rgba(56, 34, 15, 0.45); /* warm dark shadow */
              "
            >
              <img
                src="/images/<%=data.isbn%>.png"
                class="img-fluid rounded"
                style="max-width: 250px"
                alt="Book cover for <%=data.title%> by <%=data.author%>"
              />
            </div>
          </div>

          <!-- Description + Metadata -->
          <div class="col-md-8">
            <div class="text-block-wrapper" style="max-width: 600px">
              <div class="mb-3">
                <% const star = "★" %>
                <span class="metadata-line text-on-brown">
                  Rating: <%= star.repeat(data.rating) %>
                </span>
              </div>
              <div class="mb-3">
                <span class="metadata-line text-on-brown">
                  Finished: <%=data.month%> <%=data.year%>
                </span>
              </div>
              <p class="notes-text text-on-brown">
                <%- (data.notes || "").replace(/\n/g, '<br />') %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>
    <%- include('footer.ejs'); %> <%- include('script.ejs'); %>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css"
      integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/style.css">

   <title>Book Journal Portfolio Project</title>
  </head>
  <body>
    <main>
      <section class="pt-5 text-center background-wave">
        <div class="row">
        <div class="col-lg-6 col-md-8 mx-auto">
          <%- include('header.ejs')%>
            <p>
            <a href="/add" class="btn btn-outline-dark" id="add">Add a book</a>
            </p>
            <p>
            <a href="/newest" class="btn btn-outline-dark" id="newest">Newest First</a>
            <a href="/highest" class="btn btn-outline-dark" id="newest">Highest Rated First</a>
            </p>
        </div>
        </div>
      </section>
      <%- include('header_wave.ejs') %>
      <div class="album pt-5 bg-body-tertiary pb-4">
        <div class="container">
          <div class="row">
            <% for (let i = 0; i < locals.data.length; i++){%>
            <div class="col-10 col-sm-6 col-md-4 col-lg-4">
              <div class="card shadow-sm my-2">
                    <% let imgUrl = "/images/" + locals.data[i].isbn + '.png'; %>
                    <img src=<%=imgUrl%>>
                    <div class="card-body">
                        <p class="card-text">
                            <%=locals.data[i].title%>
                            <br />
                            <%=locals.data[i].author%>
                            <br />
                            <% if (locals.data[i].year != null) {%>
                                <small class="text-body-secondary">Read <%=locals.data[i].month%> <%=locals.data[i].year%></small>
                            <%};%>
                            <%const star = "★"%>
                            <p>Rating: <%=star.repeat(locals.data[i].rating)%></p>
                        </p></p>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="btn-group">
                            <a href="/view?id=<%=locals.data[i].id%>"><button
                                type="button"
                                class="btn btn-sm btn-outline-dark mr-1"
                            > View </button></a>
                            <a href="/edit?id=<%=locals.data[i].id%>"><button
                                type="button"
                                class="btn btn-sm btn-outline-dark mr-1"
                            > Edit </button></a>
                            <!-- <a href="/delete?id=<%=locals.data[i].id%>"><button
                                type="button"
                                class="btn btn-sm btn-outline-dark mr-1"
                            > Delete </button></a> -->
                        </div>
                  </div>
                </div>
              </div>
            </div>
            <%};%>
          </div>
        </div>
      </div>
    </main> 
    <%- include('footer.ejs'); %>
    <script
      src="/docs/5.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      class="astro-vvvwv3sm"
    ></script>
    <script
      type="text/javascript"
      id="id-ai-highlight"
      src="moz-extension://08f4d140-5935-45a2-bf12-ff85a59d4444/ai-highlight.js"
    ></script>
    <script
      src="https://code.jquery.com/jquery-3.2.1.slim.min.js"
      integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js"
      integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/js/bootstrap.min.js"
      integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl"
      crossorigin="anonymous"
    ></script>
  </body>
</html>

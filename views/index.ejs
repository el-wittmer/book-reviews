<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css"
      integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/style.css">

   <title>Book Journal Portfolio Project</title>
  </head>
  <body>
    <main>
      <section class="pt-5 text-center container">
        <div class="row py-lg-3">
          <div class="col-lg-6 col-md-8 mx-auto">
            <h1 class="fw-light">Book Journal</h1>
            <p class="lead text-body-secondary">
              A portfolio project by <a href="https://github.com/el-wittmer">@el-wittmer</a>
            </p>
            <p>
              <a href="/add" class="btn btn-outline-dark my-2" id="add">Add a book</a>
            </p>
            <p>
              <a href="/newest" class="btn btn-outline-dark my-2" id="newest">Newest First</a>
              <a href="/liked" class="btn btn-outline-dark my-2" id="liked">Liked</a>
              <a href="/owned" class="btn btn-outline-dark my-2" id="liked">My Bookshelf</a>
            </p>
          </div>
        </div>
      </section>
      <div class="album pt-5 bg-body-tertiary pb-4">
        <div class="container">
          <div class="row">
            <% for (let i = 0; i < locals.data.length; i++){%>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
              <div class="card shadow-sm my-2">
                    <% let imgUrl = "/images/" + locals.data[i].isbn + '.png'; %>
                    <img src=<%=imgUrl%>>
                    <div class="card-body">
                        <p class="card-text">
                            <%=locals.data[i].title%>
                            <br />
                            <%=locals.data[i].author%>
                            <br />
                            <% if (locals.data[i].year_read != null) {%>
                                <small class="text-body-secondary">Read <%=locals.data[i].month_read%> <%=locals.data[i].year_read%></small>
                            <%};%>
                            <div class="d-flex flex-row"> 
                                <% if (locals.data[i].liked) { %>
                                    <div class="tag">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-hand-thumbs-up" viewBox="0 0 16 16">
                                            <path d="M8.864.046C7.908-.193 7.02.53 6.956 1.466c-.072 1.051-.23 2.016-.428 2.59-.125.36-.479 1.013-1.04 1.639-.557.623-1.282 1.178-2.131 1.41C2.685 7.288 2 7.87 2 8.72v4.001c0 .845.682 1.464 1.448 1.545 1.07.114 1.564.415 2.068.723l.048.03c.272.165.578.348.97.484.397.136.861.217 1.466.217h3.5c.937 0 1.599-.477 1.934-1.064a1.86 1.86 0 0 0 .254-.912c0-.152-.023-.312-.077-.464.201-.263.38-.578.488-.901.11-.33.172-.762.004-1.149.069-.13.12-.269.159-.403.077-.27.113-.568.113-.857 0-.288-.036-.585-.113-.856a2 2 0 0 0-.138-.362 1.9 1.9 0 0 0 .234-1.734c-.206-.592-.682-1.1-1.2-1.272-.847-.282-1.803-.276-2.516-.211a10 10 0 0 0-.443.05 9.4 9.4 0 0 0-.062-4.509A1.38 1.38 0 0 0 9.125.111zM11.5 14.721H8c-.51 0-.863-.069-1.14-.164-.281-.097-.506-.228-.776-.393l-.04-.024c-.555-.339-1.198-.731-2.49-.868-.333-.036-.554-.29-.554-.55V8.72c0-.254.226-.543.62-.65 1.095-.3 1.977-.996 2.614-1.708.635-.71 1.064-1.475 1.238-1.978.243-.7.407-1.768.482-2.85.025-.362.36-.594.667-.518l.262.066c.16.04.258.143.288.255a8.34 8.34 0 0 1-.145 4.725.5.5 0 0 0 .595.644l.003-.001.014-.003.058-.014a9 9 0 0 1 1.036-.157c.663-.06 1.457-.054 2.11.164.175.058.45.3.57.65.107.308.087.67-.266 1.022l-.353.353.353.354c.043.043.105.141.154.315.048.167.075.37.075.581 0 .212-.027.414-.075.582-.05.174-.111.272-.154.315l-.353.353.353.354c.047.047.109.177.005.488a2.2 2.2 0 0 1-.505.805l-.353.353.353.354c.006.005.041.05.041.17a.9.9 0 0 1-.121.416c-.165.288-.503.56-1.066.56z"/>
                                        </svg>
                                    </div>
                                <% }; %>
                                <%if (locals.data[i].audio) { %>
                                    <div class="tag">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-headphones" viewBox="0 0 16 16">
                                            <path d="M8 3a5 5 0 0 0-5 5v1h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V8a6 6 0 1 1 12 0v5a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1V8a5 5 0 0 0-5-5"/>
                                        </svg>
                                    </div>
                                <% }; %>
                            </div>
                            <%=locals.data[i].notes.substring(0, 150)%>...
                        </p>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="btn-group">
                            <a href="/view?id=<%=locals.data[i].id%>"><button
                                type="button"
                                class="btn btn-sm btn-outline-secondary mx-1"
                            > View </button></a>
                            <a href="/edit?id=<%=locals.data[i].id%>"><button
                                type="button"
                                class="btn btn-sm btn-outline-secondary mx-1"
                            > Edit </button></a>
                        </div>
                  </div>
                </div>
              </div>
            </div>
            <%};%>
          </div>
        </div>
      </div>
    </main>
    <footer class="text-body-secondary py-4">
      <p class="foot ml-5">
        Built using Node.js and PostgreSQL
      </p>
    </footer>
    <script
      src="/docs/5.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      class="astro-vvvwv3sm"
    ></script>
    <script
      type="text/javascript"
      id="id-ai-highlight"
      src="moz-extension://08f4d140-5935-45a2-bf12-ff85a59d4444/ai-highlight.js"
    ></script>
    <script
      src="https://code.jquery.com/jquery-3.2.1.slim.min.js"
      integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js"
      integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/js/bootstrap.min.js"
      integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
